NODE_ENV=development
PORT=4000

# Database
MONGO_URI=mongodb://localhost:27017/fairsight

# ML service. PYTHON_SERVICE_URL is preferred; ML_SERVICE_URL is supported for Docker compatibility.
PYTHON_SERVICE_URL=http://localhost:8000
ML_SERVICE_URL=http://localhost:8000

# Optional narrative generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Auth
AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL_HOURS=168

# Frontend origins
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Storage and safety limits
DATA_DIR=./src/data
MAX_UPLOAD_BYTES=536870912
ANALYSIS_RATE_LIMIT_MAX=20
